# .gcloudignore
# これに指定されたファイルは Cloud Run へのデプロイ時に無視されます。

# Git 関連
.git/
.gitignore

# Python 関連
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/

# 環境変数・秘密情報 (万が一作成した場合のため)
.env
.env.local
.env.*
*.json
!project-*.json  # もし特定のJSONが必要な場合はここを調整

# エディタ・OS 関連
.vscode/
.idea/
.DS_Store
Thumbs.db

# このファイル自体
.gcloudignore
